<configuration>
    <system.webServer>
        <httpProtocol>
            <customHeaders>
                <remove name="X-Powered-By" />
                <remove name="X-AspNet-Version" />
                <remove name="X-AspNetMvc-Version" />
                <remove name="Server" />
                <add name="Server"
                     value="Server" />
                <add name="X-Frame-Options"
                     value="SAMEORIGIN" />
                <add name="Strict-Transport-Security"
                     value="max-age=31536000; includeSubDomains" />
                <add name="X-Content-Type-Options"
                     value="nosniff" />
                <add name="Content-Security-Policy"
                     value="default-src 'self';
                            script-src 'self' 'unsafe-eval';
                            style-src 'self' 'unsafe-inline';
                            img-src 'self' data: blob:;
                            font-src 'self' data: blob:;
                            media-src 'self' data: blob:;
                            object-src 'none';
                            connect-src 'self' wss://*.service.signalr.net https://*.service.signalr.net;" />
                <add name="Referrer-Policy"
                     value="no-referrer" />
                <add name="X-XSS-Protection"
                     value="1; mode=block" />
            </customHeaders>
        </httpProtocol>
        <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="4294967295" />
            </requestFiltering>
        </security>
        <serverRuntime uploadReadAheadSize="1048576" />
        <aspNetCore requestTimeout="00:45:00" />
    </system.webServer>
</configuration>