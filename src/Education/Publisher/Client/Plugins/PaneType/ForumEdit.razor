<Toolbar>
    <Left>
        @if (Model.ReadOnly)
        {
            <ButtonEdit Clicked="() => Model.Edit()" />
        }
        else
        {
            <ButtonGroup>
                <ButtonSave Clicked="() => Model.Save()" />
                <ButtonCancel Clicked="HandleCancelClicked" />
            </ButtonGroup>
        }
    </Left>
</Toolbar>
<Waiter Model="Model">
    @if (Model.Entity is not null)
    {
        <Padding Size="Padding.Sizes.Small"
                 Direction="Padding.Directions.Vertical">
            <Wrapped Alignment="Wrapped.Alignments.Top">
                <Field Label="Name"
                       Size="Field.Sizes.Wide">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="75"
                             @bind-Value="Model.Entity.Name" />
                </Field>
                <Field Label="Description"
                       Size="Field.Sizes.Full"
                       Container="Field.Containers.Div">
                    <HtmlEditor ReadOnly="Model.ReadOnly"
                                @bind-Value="Model.Entity.Description" />
                </Field>
                <Field Label="Body Template"
                       Size="Field.Sizes.Medium">
                    <Dropdown ReadOnly="Model.ReadOnly"
                              LookupValues="Model.BodyTemplateNames"
                              @bind-Value="Model.Entity.BodyTemplateId" />
                </Field>
                <Field Label="District"
                       Size="Field.Sizes.Large">
                    <Dropdown ReadOnly="Model.ReadOnly"
                              AllowNull="true"
                              NullText="[All]"
                              LookupValues="Model.DistrictNames"
                              @bind-Value="Model.Entity.DistrictId" />
                </Field>
                <Field Label="School"
                       Size="Field.Sizes.Large">
                    <Dropdown ReadOnly="Model.ReadOnly"
                              AllowNull="true"
                              NullText="[All]"
                              LookupValues="Model.SchoolNames"
                              @bind-Value="Model.Entity.SchoolId" />
                </Field>
            </Wrapped>
            <Wrapped>
                <Field Label="Options"
                       Container="Field.Containers.Div">
                    <Wrapped NoWrap="true">
                        <Checkbox Label="Innovators Only"
                                  ReadOnly="Model.ReadOnly"
                                  @bind-Value="Model.Entity.InnovatorsOnly" />
                    </Wrapped>
                </Field>
            </Wrapped>
        </Padding>
    }
</Waiter>