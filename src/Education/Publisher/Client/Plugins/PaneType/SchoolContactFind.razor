<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="school contacts" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Name"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <ContactDisplay Contact="card.Entity.Contact"
                                User="card.Entity.User">
                    <Field Size="Field.Sizes.Unspecified">
                        <Labeled Width="6em"
                                 Label="Title"
                                 StringValue="@card.Entity.TitleName" />
                        <Labeled Width="6em"
                                 Label="Test Account"
                                 BooleanValue="@card.Entity.TestAccount" />
                        <Labeled Width="6em"
                                 Label="Treatment"
                                 BooleanValue="@card.Entity.Treatment" />
                        <Labeled Width="6em"
                                 Label="School"
                                 StringValue="@card.Entity.SchoolName"
                                 StringUrl="@($"/districts/district-{card.Entity.DistrictId:D}/school-{card.Entity.SchoolId:D}")" />
                        <Labeled Width="6em"
                                 Label="District"
                                 StringValue="@card.Entity.DistrictName"
                                 StringUrl="@($"/districts/district-{card.Entity.DistrictId:D}")" />
                    </Field>
                </ContactDisplay>
            </Values>
            <PaneLinks>
                <PaneLink Href="@($"{Path}/school-contact-{card.Entity.Id:D}?pane=relations")"
                          Text="Relations" />
            </PaneLinks>
            <Buttons>
                <ButtonView Href="@($"{Path}/school-contact-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}