<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Field Label="Status"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.ContentStatusNames"
                             @bind-SelectedValues="Model.Search.Status" />
            </Field>
            <Field Label="Grade"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.GradeNames"
                             @bind-SelectedValues="Model.Search.Grades" />
            </Field>
            <Field Label="Assessment Level"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.AssessmentLevelNames"
                             @bind-SelectedValues="Model.Search.AssessmentLevels" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Game"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="games" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Key"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.MediumSmall">
                    <Labeled Width="5em"
                             Label="Title"
                             StringValue="@card.Entity.Title" />
                    <Labeled CssClass="status"
                             Width="5em"
                             Label="Status">
                        <StatusDisplay Id="@card.Entity.StatusId"
                                       Name="@card.Entity.StatusName"
                                       ColorClassFrom="ContentStatusColors.For" />
                    </Labeled>
                    <Labeled Width="5em"
                             Label="Grade"
                             StringValue="@card.Entity.GradeName" />
                    @*                    <Labeled Width="5em"
                             Label="Icon"
                             StringValue="@card.Entity.IconName" />
*@
                </Field>
                <Field Size="Field.Sizes.Unspecified">
                    <Labeled Width="7em"
                             Label="Assessment"
                             StringValue="@card.Entity.AssessmentLevelKey" />
                    <Labeled Width="7em"
                             Label="Requires"
                             StringValue="@card.Entity.RequiresAchievementTitle" />
                    <Labeled Width="7em"
                             Label="Generates"
                             StringValue="@card.Entity.GeneratesAchievementTitle" />
                </Field>
            </Values>
            <PaneLinks>
                <PaneLink Href="@($"{Path}/game-{card.Entity.Id:D}?pane=sections")"
                          Text="Sections"
                          Count="card.Entity.GameSectionCount" />
            </PaneLinks>
            <Buttons>
                <ButtonView Href="@($"{Path}/game-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}