<ListOrderables Model="Model"
                T="ReadQuestionModel"
                EntityName="Question"
                UrlPrefix="@($"{Path}/read-question")"
                DeleteRequested="id => Model.Delete(id)"
                MoveUpRequested="id => Model.MoveUp(id)"
                MoveDownRequested="id => Model.MoveDown(id)">
    <ReadView>
        <Field Size="Field.Sizes.Tiny">
            <Labeled Width="7em"
                     Label="Is Preview"
                     BooleanValue="@context.ReadQuestion.IsPreview" />
            <Labeled Width="7em"
                     Label="Page Break"
                     BooleanValue="@context.ReadQuestion.PageBreakBefore" />
            <Labeled Width="7em"
                     Label="Has Correct"
                     BooleanValue="@context.ReadQuestion.HasCorrectChoice" />
            <Labeled Width="7em"
                     Label="Require Text"
                     BooleanValue="@context.ReadQuestion.RequireTextInput" />
        </Field>
        <Field Size="Field.Sizes.MediumLarge">
            <LabeledHtml Label="Text"
                         HtmlValue="@context.ReadQuestion.Text" />
        </Field>
        <Field Size="Field.Sizes.Unspecified">
            <LabeledBatch Label="Choices"
                          Width="5em"
                          Items="context.ReadQuestion.ReadChoices.OrderBy(x => x.Ordinal)"
                          Context="item">
                <ReadView>
                    <span style="@(item.IsCorrect == true ? "font-weight: bold;" : String.Empty)">
                        @(item.Text)
                    </span>
                </ReadView>
            </LabeledBatch>
        </Field>
    </ReadView>
</ListOrderables>