<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="District"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="districts" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Name"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <OrganizationDisplay Organization="card.Entity.Organization">
                    <UsaPostalDisplay UsaPostal="card.Entity.UsaPostal">
                        <Field Size="Field.Sizes.Unspecified">
                            <Labeled Width="8em"
                                     Label="Student Id Number Label"
                                     StringValue="@card.Entity.StudentIdNumberLabel" />
                            <Labeled Width="8em"
                                     Label="Assessment Explainer"
                                     StringValue="@card.Entity.AssessmentExplainer" />
                        </Field>
                    </UsaPostalDisplay>
                </OrganizationDisplay>
            </Values>
            <PaneLinks>
                <PaneLink Href="@($"{Path}/district-{card.Entity.Id:D}?pane=contacts")"
                          Text="Contacts"
                          Count="card.Entity.DistrictContactCount" />
                <PaneLink Href="@($"{Path}/district-{card.Entity.Id:D}?pane=communities")"
                          Text="Communities"
                          Count="card.Entity.CommunityCount" />
                <PaneLink Href="@($"{Path}/district-{card.Entity.Id:D}?pane=schools")"
                          Text="Schools"
                          Count="card.Entity.SchoolCount" />
            </PaneLinks>
            <Buttons>
                <ButtonView Href="@($"{Path}/district-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}