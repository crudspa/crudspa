<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Grade"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.GradeNames"
                             @bind-SelectedValues="Model.Search.Grades" />
            </Field>
            <Field Label="Status"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.ContentStatusNames"
                             @bind-SelectedValues="Model.Search.Status" />
            </Field>
            <Field Label="Available Start"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.AvailableStartRange" />
            </Field>
            <Field Label="Available End"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.AvailableEndRange" />
            </Field>
            <Field Label="Category"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.ContentCategoryNames"
                             @bind-SelectedValues="Model.Search.Categories" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Assessment"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="assessments" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Name"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.Medium">
                    <Labeled CssClass="status"
                             Width="9em"
                             Label="Status">
                        <StatusDisplay Id="@card.Entity.StatusId"
                                       Name="@card.Entity.StatusName"
                                       ColorClassFrom="ContentStatusColors.For" />
                    </Labeled>
                    <Labeled Width="9em"
                             Label="Available Start"
                             DateOnlyValue="@card.Entity.AvailableStart" />
                    <Labeled Width="9em"
                             Label="Available End"
                             DateOnlyValue="@card.Entity.AvailableEnd" />
                    <Labeled Width="9em"
                             Label="Category"
                             StringValue="@card.Entity.CategoryName" />
                </Field>
            </Values>
            <PaneLinks>
                <PaneLink Href="@($"{Path}/assessment-{card.Entity.Id:D}?pane=vocab")"
                          Text="Vocab"
                          Count="card.Entity.VocabPartCount" />
                <PaneLink Href="@($"{Path}/assessment-{card.Entity.Id:D}?pane=listening")"
                          Text="Listening"
                          Count="card.Entity.ListenPartCount" />
                <PaneLink Href="@($"{Path}/assessment-{card.Entity.Id:D}?pane=reading")"
                          Text="Reading"
                          Count="card.Entity.ReadPartCount" />
            </PaneLinks>
            <Buttons>
                <ButtonView Href="@($"{Path}/assessment-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}