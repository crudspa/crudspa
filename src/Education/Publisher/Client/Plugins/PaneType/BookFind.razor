<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Field Label="Status"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.ContentStatusNames"
                             @bind-SelectedValues="Model.Search.Status" />
            </Field>
            <Field Label="Season"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.BookSeasonNames"
                             @bind-SelectedValues="Model.Search.Seasons" />
            </Field>
            <Field Label="Category"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.BookCategoryNames"
                             @bind-SelectedValues="Model.Search.Categories" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Book"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="books" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Title"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.Unspecified">
                    <Image ImageFile="card.Entity.CoverImageFile"
                           Width="160" />
                </Field>
                <Field Size="Field.Sizes.Unspecified">
                    <Labeled CssClass="status"
                             Width="6em"
                             Label="Status">
                        <StatusDisplay Id="@card.Entity.StatusId"
                                       Name="@card.Entity.StatusName"
                                       ColorClassFrom="ContentStatusColors.For" />
                    </Labeled>
                    <Labeled Width="6em"
                             Label="Key"
                             StringValue="@card.Entity.Key" />
                    <Labeled Width="6em"
                             Label="Author"
                             StringValue="@card.Entity.Author" />
                    <Labeled Width="6em"
                             Label="ISBN"
                             StringValue="@card.Entity.Isbn" />
                    <Labeled Width="6em"
                             Label="Lexile"
                             StringValue="@card.Entity.Lexile" />
                    <Labeled Width="6em"
                             Label="Category"
                             StringValue="@card.Entity.CategoryName" />
                    <Labeled Width="6em"
                             Label="Season"
                             StringValue="@card.Entity.SeasonName" />
                </Field>
            </Values>
            <PaneLinks>
                <PaneLink Href="@($"{Path}/book-{card.Entity.Id:D}?pane=preface")"
                          Text="Preface"
                          Count="card.Entity.PrefaceCount" />
                <PaneLink Href="@($"{Path}/book-{card.Entity.Id:D}?pane=chapters")"
                          Text="Chapters"
                          Count="card.Entity.ChapterCount" />
                <PaneLink Href="@($"{Path}/book-{card.Entity.Id:D}?pane=games")"
                          Text="Games"
                          Count="card.Entity.GameCount" />
                <PaneLink Href="@($"{Path}/book-{card.Entity.Id:D}?pane=modules")"
                          Text="Modules"
                          Count="card.Entity.ModuleCount" />
                <PaneLink Href="@($"{Path}/book-{card.Entity.Id:D}?pane=trifolds")"
                          Text="Trifolds"
                          Count="card.Entity.TrifoldCount" />
                <PaneLink Href="@($"{Path}/book-{card.Entity.Id:D}?pane=relations")"
                          Text="Relations" />
            </PaneLinks>
            <Buttons>
                <ButtonView Href="@($"{Path}/book-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}