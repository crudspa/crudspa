<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Field Label="Grade"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.GradeNames"
                             @bind-SelectedValues="Model.Search.Grades" />
            </Field>
            <Field Label="Assessment Level"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.AssessmentLevelNames"
                             @bind-SelectedValues="Model.Search.AssessmentLevelGroups" />
            </Field>
            <Field Label="Filters"
                   Container="Field.Containers.Div">
                <Wrapped NoWrap="true">
                    <Checkbox Label="Not in classroom"
                              AlsoValueChanged="() => Model.Refresh()"
                              @bind-Value="Model.Search.NotInClassroom" />
                    <Checkbox Label="Include test accounts"
                              AlsoValueChanged="() => Model.Refresh()"
                              @bind-Value="Model.Search.IncludeTestAccounts" />
                </Wrapped>
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Student"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="students" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Name"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.Large">
                    <Labeled Width="8em"
                             Label="Id Number"
                             StringValue="@(card.Entity.IdNumber)" />
                    <Labeled Width="8em"
                             Label="Grade"
                             StringValue="@(card.Entity.GradeName)" />
                    <Labeled Width="8em"
                             Label="Assessment"
                             StringValue="@(card.Entity.FriendlyAssessmentLevel)" />
                    <Labeled Width="8em"
                             Label="Secret Code"
                             StringValue="@(card.Entity.SecretCode)" />
                    <Labeled Width="8em"
                             Label="Preferred"
                             StringValue="@(card.Entity.PreferredName)" />
                </Field>
                @if (card.Entity.AvatarString is not null)
                {
                    <Field Size="Field.Sizes.Unspecified">
                        <div style="font-size: 2.4em;">
                            @card.Entity.AvatarString
                        </div>
                    </Field>
                }
            </Values>
            <Buttons>
                <ButtonView Href="@($"{Path}/student-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}