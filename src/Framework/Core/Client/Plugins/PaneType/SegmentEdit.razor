<Toolbar>
    <Left>
        <ButtonGroup>
            @if (Model.ReadOnly)
            {
                <ButtonEdit Clicked="() => Model.Edit()" />
            }
            else
            {
                <ButtonSave Clicked="HandleSaveClicked" />
                <ButtonCancel Clicked="HandleCancelClicked" />
            }
        </ButtonGroup>
    </Left>
</Toolbar>
<Waiter Model="Model">
    @if (Model.Entity is not null)
    {
        <Padding Size="Padding.Sizes.Small"
                 Direction="Padding.Directions.Vertical">
            <Wrapped Alignment="Wrapped.Alignments.Top">
                <Field Label="Key"
                       Size="Field.Sizes.Medium">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="100"
                             @bind-Value="Model.Entity.Key" />
                </Field>
                <Field Label="Status"
                       Size="Field.Sizes.Unspecified">
                    <StatusEdit ReadOnly="Model.ReadOnly"
                                LookupValues="Model.ContentStatusNames"
                                ColorClassFrom="ContentStatusColors.For"
                                @bind-Value="Model.Entity.StatusId" />
                </Field>
                <Field Label="Title"
                       Size="Field.Sizes.Wide">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="150"
                             @bind-Value="Model.Entity.Title" />
                </Field>
                <Field Label="Permission"
                       Size="Field.Sizes.Medium">
                    <Dropdown ReadOnly="Model.ReadOnly"
                              AllowNull="true"
                              NullText="[Public]"
                              LookupValues="Model.PermissionNames"
                              @bind-Value="Model.Entity.PermissionId" />
                </Field>
                <Field Label="Icon"
                       Size="Field.Sizes.Medium">
                    <IconDropdown ReadOnly="Model.ReadOnly"
                                  AllowNull="true"
                                  NullText="[None]"
                                  LookupValues="Model.Icons"
                                  @bind-Value="Model.Entity.IconId" />
                </Field>
                <Field Label="Type"
                       Size="Field.Sizes.Medium">
                    <Dropdown ReadOnly="Model.ReadOnly"
                              LookupValues="Model.SegmentTypes"
                              Value="Model.Entity.TypeId"
                              ValueChanged="value => Model.SetSegmentType(value)" />
                </Field>
            </Wrapped>
            <Wrapped>
                <Field Label="Options"
                       Container="Field.Containers.Div">
                    <Wrapped NoWrap="true">
                        <Checkbox Label="Fixed"
                                  ReadOnly="Model.ReadOnly"
                                  @bind-Value="Model.Entity.Fixed" />
                        <Checkbox Label="Requires ID"
                                  ReadOnly="Model.ReadOnly"
                                  @bind-Value="Model.Entity.RequiresId" />
                        <Checkbox Label="Recursive"
                                  ReadOnly="Model.ReadOnly"
                                  @bind-Value="Model.Entity.Recursive" />
                        <Checkbox Label="All Licenses"
                                  ReadOnly="Model.ReadOnly"
                                  @bind-Value="Model.Entity.AllLicenses" />
                    </Wrapped>
                </Field>
            </Wrapped>
            @if (Model.Entity.AllLicenses == false)
            {
                <Wrapped>
                    <Field Size="Field.Sizes.Large"
                           Label="Licenses"
                           Container="Field.Containers.Div">
                        <CheckedList ReadOnly="Model.ReadOnly"
                                     Selectables="Model.Entity.Licenses" />
                    </Field>
                </Wrapped>
            }
            @if (Model.SelectedSegmentType?.EditorView.HasSomething() == true)
            {
                <Padding Size="Padding.Sizes.Small"
                         Direction="Padding.Directions.Vertical">
                    <CascadingValue Name="ReadOnly"
                                    Value="Model.ReadOnly">
                        <SegmentDesignPlugin TypeName="@Model.SelectedSegmentType!.EditorView"
                                             Path="@Path"
                                             Id="@Id"
                                             ConfigJson="@Model.Entity.ConfigJson"
                                             Panes="@Model.Entity.Panes"
                                             PanesModel="@Model.PanesModel"
                                             PermissionNames="@Model.PermissionNames"
                                             PaneTypes="@Model.PaneTypes"
                                             AddPane="@Model.AddPane"
                                             @key="Model.Entity"
                                             @ref="DesignComponent" />
                    </CascadingValue>
                </Padding>
            }
        </Padding>
    }
</Waiter>