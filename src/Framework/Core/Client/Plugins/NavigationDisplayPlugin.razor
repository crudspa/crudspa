@namespace Crudspa.Framework.Core.Client.Plugins
@PluginFragment

@code
{
    [Parameter, EditorRequired] public String? TypeName { get; set; } = String.Empty;
    [Parameter, EditorRequired] public Portal Portal { get; set; } = null!;
    [Parameter] public RenderFragment? Branding { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public RenderFragment? AuthViews { get; set; }
    [Parameter] public String? Styles { get; set; }

    public Object? Instance { get; private set; }

    private RenderFragment PluginFragment => builder =>
    {
        if (TypeName.HasNothing())
            throw new("TypeName was not supplied.");

        var pluginType = Type.GetType(TypeName)
            ?? throw new($"Component type '{TypeName}' not found.");

        if (!typeof(INavigationDisplay).IsAssignableFrom(pluginType))
            throw new($"Interface '{nameof(INavigationDisplay)}' is not implemented by the component '{TypeName}'.");

        builder.OpenComponent(0, pluginType);

        builder.AddAttribute(1, nameof(INavigationDisplay.Portal), Portal);

        if (Branding is not null)
            builder.AddAttribute(2, nameof(INavigationDisplay.Branding), Branding);

        if (Footer is not null)
            builder.AddAttribute(3, nameof(INavigationDisplay.Footer), Footer);

        if (AuthViews is not null)
            builder.AddAttribute(4, nameof(INavigationDisplay.AuthViews), AuthViews);

        if (Styles.HasSomething())
            builder.AddAttribute(5, nameof(INavigationDisplay.Styles), Styles);

        builder.AddComponentReferenceCapture(6, component => Instance = component);

        builder.CloseComponent();
    };
}