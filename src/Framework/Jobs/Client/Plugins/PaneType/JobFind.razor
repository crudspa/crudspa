<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Field Label="Type"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.JobTypeNames"
                             @bind-SelectedValues="Model.Search.Types" />
            </Field>
            <Field Label="Status"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.JobStatusNames"
                             @bind-SelectedValues="Model.Search.Status" />
            </Field>
            <Field Label="Device"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.DeviceNames"
                             @bind-SelectedValues="Model.Search.Devices" />
            </Field>
            <Field Label="Schedule"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.JobScheduleNames"
                             @bind-SelectedValues="Model.Search.Schedules" />
            </Field>
            <Field Label="Added"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.AddedRange" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Job"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="jobs" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Name"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.MediumSmall">
                    <Labeled Width="4em"
                             Label="Added"
                             DateTimeOffsetValue="card.Entity.Added" />
                    <Labeled Width="4em"
                             Label="Started"
                             DateTimeOffsetValue="card.Entity.Started" />
                    <Labeled Width="4em"
                             Label="Ended"
                             DateTimeOffsetValue="card.Entity.Ended" />
                </Field>
                <Field Size="Field.Sizes.Unspecified">
                    <Labeled CssClass="status"
                             Width="5em"
                             Label="Status">
                        <StatusDisplay Name="@(card.Entity.StatusName)"
                                       ColorClass="@card.Entity.StatusCssClass" />
                    </Labeled>
                    <Labeled Width="5em"
                             Label="Device"
                             StringValue="@(card.Entity.DeviceName)" />
                    <Labeled Width="5em"
                             Label="Schedule"
                             StringValue="@(card.Entity.ScheduleName)" />
                </Field>
            </Values>
            <Buttons>
                <ButtonView Href="@($"{Path}/job-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}