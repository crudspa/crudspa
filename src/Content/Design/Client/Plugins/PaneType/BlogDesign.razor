@using Crudspa.Content.Display.Shared.Contracts.Config.PaneType
<Waiter Model="Model">
    @if (Model.Blogs.HasItems())
    {
        <Wrapped Alignment="Wrapped.Alignments.Top">
            <Field Label="Blog ID"
                   Size="Field.Sizes.Large"
                   Container="Field.Containers.Div">
                <EnumRadio TEnum="BlogConfig.IdSources"
                           @bind-SelectedValue="@Model.Config.IdSource"
                           RadioCssClass="tight-bottom"
                           ReadOnly="@ReadOnly" />
                @if (Model.Config.IdSource == BlogConfig.IdSources.SpecificBlog)
                {
                    <Dropdown LookupValues="Model.Blogs"
                              ReadOnly="@ReadOnly"
                              @bind-Value="Model.Config.BlogId" />
                }
            </Field>
        </Wrapped>
    }
</Waiter>