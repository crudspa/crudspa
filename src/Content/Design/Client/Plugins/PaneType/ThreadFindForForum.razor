<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Field Label="Posted"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.PostedRange" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Thread"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="threads" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Title"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.Unspecified">
                    <Labeled Width="6em"
                             Label="By"
                             StringValue="@card.Entity.Comment.ByName" />
                    <Labeled Width="6em"
                             Label="Posted"
                             DateTimeOffsetValue="@card.Entity.Comment.Posted" />
                    <Labeled Width="6em"
                             Label="Edited"
                             DateTimeOffsetValue="@card.Entity.Comment.Edited" />
                    <Labeled Width="6em"
                             Label="Pinned"
                             BooleanValue="@card.Entity.Pinned" />
                </Field>
            </Values>
            <PaneLinks>
                <PaneLink Href="@($"{Path}/thread-{card.Entity.Id:D}?pane=comments")"
                          Text="Comments"
                          Count="card.Entity.CommentCount" />
            </PaneLinks>
            <Buttons>
                <ButtonView Href="@($"{Path}/thread-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}