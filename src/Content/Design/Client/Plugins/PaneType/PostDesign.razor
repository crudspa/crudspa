@using Crudspa.Content.Display.Shared.Contracts.Config.PaneType
<Waiter Model="Model">
    @if (Model.Posts.HasItems())
    {
        <Wrapped Alignment="Wrapped.Alignments.Top">
            <Field Label="Post ID"
                   Size="Field.Sizes.Large"
                   Container="Field.Containers.Div">
                <EnumRadio TEnum="PostConfig.IdSources"
                           @bind-SelectedValue="@Model.Config.IdSource"
                           RadioCssClass="tight-bottom"
                           ReadOnly="@ReadOnly" />
                @if (Model.Config.IdSource == PostConfig.IdSources.SpecificPost)
                {
                    <Dropdown LookupValues="Model.Posts"
                              ReadOnly="@ReadOnly"
                              @bind-Value="Model.Config.PostId" />
                }
            </Field>
        </Wrapped>
    }
</Waiter>