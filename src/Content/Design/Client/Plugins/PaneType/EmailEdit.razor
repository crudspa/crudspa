<Toolbar>
    <Left>
        <ButtonGroup>
            @if (Model.ReadOnly)
            {
                <ButtonEdit Clicked="() => Model.Edit()"
                            Disabled="@(Model.Entity?.Status != Email.Statuses.Scheduled)" />
            }
            else
            {
                <ButtonSave Clicked="() => Model.Save()" />
                <ButtonCancel Clicked="HandleCancelClicked" />
            }
        </ButtonGroup>
    </Left>
</Toolbar>
<Waiter Model="Model">
    @if (Model.Entity is not null)
    {
        <Modal Model="Model.TemplateModalModel"
               Title="Load Template"
               Width="32em"
               TopMargin="2em">
            <Content>
                <Padding Size="Padding.Sizes.Small"
                         Direction="Padding.Directions.Vertical">
                    <Wrapped Alignment="Wrapped.Alignments.Top">
                        <Field Label="Template"
                               Size="Field.Sizes.Full">
                            <Dropdown ReadOnly="Model.ReadOnly"
                                      LookupValues="Model.EmailTemplates"
                                      Value="Model.SelectedTemplateId"
                                      ValueChanged="id => Model.HandleTemplateChanged(id)" />
                        </Field>
                        @if (Model.SelectedTemplate is not null)
                        {
                            <Field Label="Subject"
                                   Size="Field.Sizes.Full">
                                <TextBox ReadOnly="true"
                                         MaxLength="150"
                                         @bind-Value="Model.SelectedTemplate.Subject" />
                            </Field>
                            <Field Label="Body"
                                   Size="Field.Sizes.Full"
                                   Container="Field.Containers.Div">
                                <HtmlEditor ReadOnly="true"
                                            Tokens="Model.Tokens"
                                            EditorHeight="32em"
                                            DisplayHeight="32em"
                                            @bind-Value="Model.SelectedTemplate.Body" />
                            </Field>
                        }
                    </Wrapped>
                </Padding>

            </Content>
            <Buttons>
                <ButtonOk Clicked="() => Model.LoadTemplate()" />
                <ButtonCancel Clicked="() => Model.TemplateModalModel.Hide()" />
            </Buttons>
        </Modal>
        <Padding Size="Padding.Sizes.Small"
                 Direction="Padding.Directions.Vertical">
            <Wrapped Alignment="Wrapped.Alignments.Top">
                <Field Label="From Name"
                       Size="Field.Sizes.Large">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="150"
                             @bind-Value="Model.Entity.FromName" />
                </Field>
                <Field Label="From Email"
                       Size="Field.Sizes.Large">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="75"
                             @bind-Value="Model.Entity.FromEmail" />
                </Field>
                <Field Label="Template"
                       Container="Field.Containers.Div">
                    <Padding Direction="Padding.Directions.Top"
                             Size="Padding.Sizes.Tiny">
                        <ButtonCore Text="Load..."
                                    Disabled="Model.ReadOnly"
                                    Clicked="() => Model.TemplateModalModel.Show()" />
                    </Padding>
                </Field>
                <Field Label="Send"
                       Size="Field.Sizes.Small">
                    <DateTimePicker ReadOnly="Model.ReadOnly"
                                    @bind-Value="Model.Entity.Send" />
                </Field>
                <Field Label="Subject"
                       Size="Field.Sizes.Full">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="150"
                             @bind-Value="Model.Entity.Subject" />
                </Field>
                <Field Label="Body"
                       Size="Field.Sizes.Full"
                       Container="Field.Containers.Div">
                    <HtmlEditor ReadOnly="Model.ReadOnly"
                                Tokens="Model.Tokens"
                                @bind-Value="Model.Entity.Body" />
                </Field>
            </Wrapped>
        </Padding>
        <Padding Size="Padding.Sizes.Small"
                 Direction="Padding.Directions.Vertical">
            <BatchSection Title="Attachments">
                <HeadingPanel>
                    <ButtonAdd EntityName="Attachment"
                               Disabled="Model.ReadOnly"
                               Transparent="true"
                               Clicked="() => Model.AddEmailAttachment()">
                    </ButtonAdd>
                </HeadingPanel>
                <ChildContent>
                    <Batch Model="Model.EmailAttachmentsModel"
                           ReadOnly="Model.ReadOnly">
                        <EditView>
                            <Wrapped Alignment="Wrapped.Alignments.Top"
                                     @key="context">
                                <Field Label="PDF"
                                       Size="Field.Sizes.Larger"
                                       Container="Field.Containers.Div">
                                    <PdfUploader ReadOnly="Model.ReadOnly"
                                                 Required="true"
                                                 PdfFile="context.PdfFile" />
                                </Field>
                            </Wrapped>
                        </EditView>
                    </Batch>
                </ChildContent>
            </BatchSection>
        </Padding>
    }
</Waiter>