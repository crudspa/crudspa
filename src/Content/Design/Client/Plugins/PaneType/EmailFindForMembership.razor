<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Field Label="Send"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.SendRange" />
            </Field>
            <Field Label="Processed"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.ProcessedRange" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Email"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="emails" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Subject"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.Unspecified">
                    <Labeled Width="8em"
                             Label="From Name"
                             StringValue="@card.Entity.FromName" />
                    <Labeled Width="8em"
                             Label="From Email"
                             StringValue="@card.Entity.FromEmail" />
                    <Labeled Width="8em"
                             Label="Send"
                             DateTimeOffsetValue="@card.Entity.Send" />
                    <LabeledHtml Label="Body"
                                 HtmlValue="@card.Entity.Body" />
                    <Labeled Width="8em"
                             Label="Status"
                             StringValue="@card.Entity.Status.GetLabel()" />
                    <Labeled Width="8em"
                             Label="Processed"
                             DateTimeOffsetValue="@card.Entity.Processed" />
                </Field>
            </Values>
            <Buttons>
                <ButtonView Href="@($"{Path}/email-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}