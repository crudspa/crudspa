<Waiter Model="Model">
    <Filters>
        <Fields>
            <Field Label="Search"
                   Size="Field.Sizes.Medium">
                <SearchTextBox @bind-Value="Model.Search.Text" />
            </Field>
            <Field Label="Status"
                   Size="Field.Sizes.Medium">
                <MultiSelect LookupValues="Model.ContentStatusNames"
                             @bind-SelectedValues="Model.Search.Status" />
            </Field>
            <Field Label="Published"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.PublishedRange" />
            </Field>
            <Field Label="Revised"
                   Size="Field.Sizes.Medium">
                <DateFilter Range="Model.Search.RevisedRange" />
            </Field>
            <Sorter Sorts="Model.Sorts"
                    @bind-Selected="Model.Search.Sort.Field"
                    @bind-Ascending="Model.Search.Sort.Ascending" />
        </Fields>
        <Buttons>
            <ButtonAdd EntityName="Post"
                       Clicked="AddNew" />
            <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.Create">
                <MenuItem Type="MenuItem.Types.Reset"
                          Clicked="() => Model.Reset()" />
                <MenuItem Type="MenuItem.Types.Refresh"
                          Clicked="() => Model.Refresh()" />
            </ContextMenu>
        </Buttons>
    </Filters>
</Waiter>
@if (Model.Cards.IsEmpty())
{
    <NoRecords EntityName="posts" />
}
else
{
    @foreach (var card in Model.Cards)
    {
        <Card Model="card"
              Title="@card.Entity.Title"
              SupportsDelete="true"
              DeleteRequested="() => Model.Delete(card.Entity.Id)">
            <Values>
                <Field Size="Field.Sizes.MediumLarge">
                    <Labeled CssClass="status"
                             Width="5em"
                             Label="Status">
                        <StatusDisplay Id="@card.Entity.StatusId"
                                       Name="@card.Entity.StatusName"
                                       ColorClassFrom="ContentStatusColors.For" />
                    </Labeled>
                    <Labeled Width="5em"
                             Label="Author"
                             StringValue="@card.Entity.Author" />
                </Field>
                <Field Size="Field.Sizes.Unspecified">
                    <Labeled Width="6em"
                             Label="Comments"
                             StringValue="@card.Entity.CommentRule.GetLabel()" />
                    <Labeled Width="6em"
                             Label="Published"
                             DateOnlyValue="@card.Entity.Published" />
                    <Labeled Width="6em"
                             Label="Revised"
                             DateOnlyValue="@card.Entity.Revised" />
                </Field>
            </Values>
            <PaneLinks>
                <PaneLink Href="@($"{Path}/post-{card.Entity.Id:D}?pane=sections")"
                          Text="Sections"
                          Count="card.Entity.SectionCount" />
                <PaneLink Href="@($"{Path}/post-{card.Entity.Id:D}?pane=comments")"
                          Text="Comments"
                          Count="card.Entity.CommentCount" />
                <PaneLink Href="@($"{Path}/post-{card.Entity.Id:D}?pane=reactions")"
                          Text="Reactions"
                          Count="card.Entity.PostReactionCount" />
                <PaneLink Href="@($"{Path}/post-{card.Entity.Id:D}?pane=tags")"
                          Text="Tags"
                          Count="card.Entity.PostTagCount" />
            </PaneLinks>
            <Buttons>
                <ButtonView Href="@($"{Path}/post-{card.Entity.Id:D}")" />
                <ContextMenu ButtonStyle="ContextMenu.ButtonStyles.View">
                    <MenuItem Type="MenuItem.Types.Delete"
                              Clicked="() => Model.ShowConfirmation(card.Entity.Id)" />
                </ContextMenu>
            </Buttons>
        </Card>
    }

    <Pager Paged="Model.Search.Paged"
           PageNumberChanged="Model.HandlePageNumberChanged" />
}