<Many Model="Model"
      T="AchievementModel"
      EntityName="Achievement"
      SaveRequested="id => Model.Save(id)"
      CancelRequested="id => Model.Cancel(id)"
      DeleteRequested="id => Model.Delete(id)">
    <ReadView>
        <Field Size="Field.Sizes.Tiny">
            <Image ImageFile="context.Achievement.ImageFile"
                   Width="140" />
        </Field>
        <Field Size="Field.Sizes.Star">
            <LabeledHtml Label="Description"
                         HtmlValue="@context.Achievement.Description" />
        </Field>
    </ReadView>
    <EditView>
        <Wrapped Alignment="Wrapped.Alignments.Top">
            <Field Label="Title"
                   Size="Field.Sizes.Large">
                <TextBox ReadOnly="@false"
                         MaxLength="75"
                         @bind-Value="context.Achievement.Title" />
            </Field>
            <Field Label="Description"
                   Size="Field.Sizes.Full"
                   Container="Field.Containers.Div">
                <HtmlEditor ReadOnly="@false"
                            @bind-Value="context.Achievement.Description" />
            </Field>
            <Field Label="Image"
                   Size="Field.Sizes.Large"
                   Container="Field.Containers.Div">
                <ImageUploader ReadOnly="@false"
                               Required="true"
                               ImageFile="context.Achievement.ImageFile" />
            </Field>
        </Wrapped>
    </EditView>
</Many>