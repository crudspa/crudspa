<Toolbar>
    <Left>
        <ButtonGroup>
            @if (Model.ReadOnly)
            {
                <ButtonEdit Clicked="() => Model.Edit()" />
            }
            else
            {
                <ButtonSave Clicked="() => Model.Save()" />
                <ButtonCancel Clicked="HandleCancelClicked" />
            }
        </ButtonGroup>
    </Left>
</Toolbar>
<Waiter Model="Model">
    @if (Model.Entity is not null)
    {
        <Padding Size="Padding.Sizes.Small"
                 Direction="Padding.Directions.Vertical">
            <Wrapped Alignment="Wrapped.Alignments.Top">
                <Field Label="Title"
                       Size="Field.Sizes.Wide">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="75"
                             @bind-Value="Model.Entity.Title" />
                </Field>
                <Field Label="Subject"
                       Size="Field.Sizes.Full">
                    <TextBox ReadOnly="Model.ReadOnly"
                             MaxLength="150"
                             @bind-Value="Model.Entity.Subject" />
                </Field>
                <Field Label="Body"
                       Size="Field.Sizes.Full"
                       Container="Field.Containers.Div">
                    <HtmlEditor ReadOnly="Model.ReadOnly"
                                Tokens="Model.Tokens"
                                @bind-Value="Model.Entity.Body" />
                </Field>
            </Wrapped>
        </Padding>
    }
</Waiter>