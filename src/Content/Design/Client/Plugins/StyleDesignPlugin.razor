@namespace Crudspa.Content.Design.Client.Plugins
@PluginFragment

@code
{
    [Parameter, EditorRequired] public String? TypeName { get; set; } = String.Empty;
    [Parameter] public String? ConfigJson { get; set; }
    [Parameter] public Guid? ContentPortalId { get; set; }

    public Object? Instance { get; private set; }

    private RenderFragment PluginFragment => builder =>
    {
        if (TypeName.HasNothing())
            throw new("TypeName was not supplied.");

        var pluginType = Type.GetType(TypeName)
            ?? throw new($"Component type '{TypeName}' not found.");

        if (!typeof(IStyleDesign).IsAssignableFrom(pluginType))
            throw new($"Interface '{nameof(IStyleDesign)}' is not implemented by the component '{TypeName}'.");

        builder.OpenComponent(0, pluginType);

        if (ConfigJson.HasSomething())
            builder.AddAttribute(1, nameof(IStyleDesign.ConfigJson), ConfigJson);

        if (ContentPortalId.HasSomething())
            builder.AddAttribute(2, nameof(IStyleDesign.ContentPortalId), ContentPortalId);

        builder.AddComponentReferenceCapture(3, component => Instance = component);

        builder.CloseComponent();
    };
}