@namespace Crudspa.Content.Display.Client.Plugins
@PluginFragment

@code
{
    [Parameter, EditorRequired] public String? TypeName { get; set; } = String.Empty;
    [Parameter] public String? Path { get; set; }
    [Parameter] public Guid? Id { get; set; }
    [Parameter] public String? ConfigJson { get; set; }
    [Parameter] public EventCallback BinderCompleted { get; set; }
    [Parameter] public ImageFile? GuideImage { get; set; }
    [Parameter] public Boolean Shadowed { get; set; }

    public Object? Instance { get; private set; }

    private RenderFragment PluginFragment => builder =>
    {
        if (TypeName.HasNothing())
            throw new("TypeName was not supplied.");

        var pluginType = Type.GetType(TypeName)
            ?? throw new($"Component type '{TypeName}' not found.");

        if (!typeof(IBinderDisplay).IsAssignableFrom(pluginType))
            throw new($"Interface '{nameof(IBinderDisplay)}' is not implemented by the component '{TypeName}'.");

        builder.OpenComponent(0, pluginType);

        if (Path.HasSomething())
            builder.AddAttribute(1, nameof(IBinderDisplay.Path), Path);

        if (Id.HasSomething())
            builder.AddAttribute(2, nameof(IBinderDisplay.Id), Id);

        if (ConfigJson.HasSomething())
            builder.AddAttribute(3, nameof(IBinderDisplay.ConfigJson), ConfigJson);

        if (BinderCompleted.HasDelegate)
            builder.AddAttribute(4, nameof(IBinderDisplay.BinderCompleted), BinderCompleted);

        if (GuideImage is not null)
            builder.AddAttribute(5, nameof(IBinderDisplay.GuideImage), GuideImage);

        builder.AddAttribute(6, nameof(IBinderDisplay.Shadowed), Shadowed);

        builder.AddComponentReferenceCapture(7, component => Instance = component);

        builder.CloseComponent();
    };
}